@model IEnumerable<InterviewCoach.Models.Story>

@{
    ViewData["Title"] = "Manage Stories";
}

<h1>Manage Your Interview Stories</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add Custom Story</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Question</th>
            <th>Situation</th>
            <th>Last Updated</th>
            <th>Score</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                <strong>@item.Question?.QuestionText</strong><br/>
                <small class="text-muted">@item.Question?.Competency / @item.Question?.QuestionType</small>
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Situation)
            </td>
            <td>
                @(item.CreatedAt == DateTime.MinValue ? "Not Started" : item.CreatedAt.ToShortDateString())
            </td>
            <td>
                @(item.CreatedAt == DateTime.MinValue ? "-" : item.OverallScore.ToString("F1"))
            </td>
            <td>
                @if (item.Id == 0)
                {
                    <a asp-action="Edit" asp-route-questionId="@item.QuestionId" class="btn btn-sm btn-primary">Start Story</a>
                    <a asp-action="Details" asp-route-questionId="@item.QuestionId" class="btn btn-sm btn-outline-secondary">Details</a>
                }
                else
                {
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit Story</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                }
            </td>
        </tr>
}
    </tbody>
</table>
